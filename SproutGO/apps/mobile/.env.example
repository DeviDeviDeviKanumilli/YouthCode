# SproutGo mobile env — copy to `apps/mobile/.env` (gitignored) and fill real values.
# Only EXPO_PUBLIC_* values reach the app bundle; MAPBOX_DOWNLOAD_TOKEN is build-time only.
# Full setup: currentPlans/DEV_BUILD.md.

# --- Build-time (NOT bundled) ----------------------------------------------
# Mapbox SECRET download token (starts sk., scope DOWNLOADS:READ). Needed by `pod install`
# during `npm run prebuild:ios` / `npm run ios`. Without it the iOS build fails.
# Can also be exported in your shell instead of living here.
MAPBOX_DOWNLOAD_TOKEN="sk...."

# Optional: override the iOS bundle id / Android package if the default is already taken
# under your Apple ID when signing to a physical device. Defaults to com.sproutgo.app.
# IOS_BUNDLE_ID="com.yourname.sproutgo"

# --- Runtime (safe for the client; public/restricted) ----------------------
EXPO_PUBLIC_SUPABASE_URL=""
EXPO_PUBLIC_SUPABASE_ANON_KEY=""

# PUBLIC Mapbox token (starts pk.). Restrict it to the bundle id you build with.
EXPO_PUBLIC_MAPBOX_TOKEN="pk...."

# Where the app sends API calls. IMPORTANT for a PHYSICAL iPhone: do NOT use localhost
# (that's the phone itself). Use either your deployed Vercel HTTPS URL, or your Mac's LAN
# IP over http (e.g. http://192.168.1.50:3000) while running `npm run api:dev` — the app
# is configured to allow local-network cleartext for that case.
EXPO_PUBLIC_API_BASE_URL="http://localhost:3000"
