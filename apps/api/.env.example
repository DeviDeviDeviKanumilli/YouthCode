APP_NAME=EcoSentinel API
SERVICE_NAME=ecosentinel-api
APP_ENV=development
APP_VERSION=0.1.0
API_PREFIX=/api/v1
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://ecosentinel:ecosentinel@localhost:5432/ecosentinel
REDIS_URL=redis://localhost:6379/0
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=.local/storage
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
