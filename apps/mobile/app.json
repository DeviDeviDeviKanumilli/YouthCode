{
  "expo": {
    "name": "EcoSentinel",
    "slug": "ecosentinel-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ecosentinel",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.youthcode.ecosentinel",
      "adaptiveIcon": {
        "backgroundColor": "#F4F1E8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "ios": {
      "bundleIdentifier": "com.youthcode.ecosentinel",
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-image",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow EcoSentinel to use your location for nearby ecological context."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow EcoSentinel to use your camera to capture sightings.",
          "microphonePermission": "Allow EcoSentinel to access your microphone.",
          "recordAudioAndroid": false
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "94ff12ad-fdfc-4483-b3ae-c5efb85325dd"
      }
    }
  }
}
